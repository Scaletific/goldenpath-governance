# RAG Web UI — environment variables
# Copy to .env and fill in your values before starting the backend.

# ── ChromaDB ────────────────────────────────────────────────────────
# Path to persist the vector index (relative to repo root)
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION=governance_docs

# ── Neo4j (required for graph-based retrieval) ───────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── LLM provider ─────────────────────────────────────────────────────
# Options: ollama | gemini
LLM_PROVIDER=ollama

# Ollama (local — default)
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# Gemini (cloud — set LLM_PROVIDER=gemini to enable)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# ── Phoenix observability (optional) ─────────────────────────────────
PHOENIX_WORKING_DIR=.phoenix
