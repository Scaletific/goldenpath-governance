# LLM Provider defaults
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# Cloud providers (optional — only needed if using that provider)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ChromaDB
CHROMA_PERSIST_DIR=../../.chroma

# Neo4j (graph expansion — optional, falls back to vector-only)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-password

# Supabase (Phase 1+ — conversation persistence)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=...
